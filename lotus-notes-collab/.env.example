PORT=4000
NODE_ENV=production

# Opción A — URL completa (Railway te la da automáticamente)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Opción B — Variables individuales
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lotus_notes_db
DB_USER=root
DB_PASSWORD=tu_password
DB_SSL=false

JWT_SECRET=cambia_esto_por_algo_seguro_en_produccion
JWT_EXPIRES_IN=24h

CORS_ORIGIN=https://tu-frontend.vercel.app

MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

ENABLE_AGENTS=true
REMINDER_DAYS=3

# IA (opcional)
GROQ_API_KEY=
