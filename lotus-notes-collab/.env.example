PORT=4000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lotus_domino_db
DB_USER=root
DB_PASSWORD=tu_password
JWT_SECRET=tu_clave_secreta_muy_segura
NODE_ENV=development

# JWT Configuration
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email Configuration (opcional - para notificaciones por email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=noreply@lotusdomino.com

# Agentes Automáticos
ENABLE_AGENTS=true
REMINDER_DAYS=3
